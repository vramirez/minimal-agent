# Copy this file to .env and fill in the backend you want to use.
# The `anthropic` SDK reads ANTHROPIC_API_KEY and ANTHROPIC_BASE_URL from the
# environment automatically, so swapping backends is just editing these values.
# NEVER commit your real .env — it is git-ignored.

# --- Option 1: LM Studio (free, local, offline) -------------------------------
# Start LM Studio, load a tool-capable model, run its local server, then:
#   ANTHROPIC_BASE_URL=http://localhost:1234
#   ANTHROPIC_API_KEY=lm-studio          # any non-empty string; LM Studio ignores it
#   MODEL=<the model id shown in LM Studio>

# --- Option 2: Hosted Anthropic-compatible gateway (free tier) ----------------
#   ANTHROPIC_BASE_URL=https://<gateway-host>
#   ANTHROPIC_API_KEY=<your gateway key>
#   MODEL=<a tool-capable model the gateway offers>

# --- Option 3: Real Anthropic API ---------------------------------------------
# Leave ANTHROPIC_BASE_URL unset to hit api.anthropic.com directly:
#   ANTHROPIC_API_KEY=sk-ant-...
#   MODEL=claude-haiku-4-5

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
MODEL=
