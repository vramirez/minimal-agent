# Copy this file to .env and (optionally) fill in values.
# The OpenAI SDK reads these from the environment; the defaults baked into
# agent.py already point at a local Ollama, so you can leave them blank.
# NEVER commit your real .env — it is git-ignored.

# Local Ollama (free, no key). Defaults if left blank:
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_API_KEY=ollama          # any non-empty string; Ollama ignores it
#   OPENAI_MODEL=llama3.2:latest   # must be a TOOL-CAPABLE model
#
# Reasoning-only models (e.g. deepseek-r1) do NOT support tool calling and
# Ollama will reject them with "does not support tools". Use llama3.2, qwen2.5,
# llama3.1, mistral-nemo, etc.
#
# To point at any other OpenAI-compatible server (LM Studio, a gateway, the real
# OpenAI API), just change these three values.

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
